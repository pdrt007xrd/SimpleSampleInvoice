@{
    var format = (ViewBag.Format as string ?? "fiscal").ToLowerInvariant();
    var printUrl = $"/Invoice/Print/{ViewBag.InvoiceId}?format={format}";
}

<h3 class="text-center">Vista previa de factura</h3>

<div class="mb-3 d-flex gap-2 flex-wrap">
    <a class="btn @(format == "clasico" ? "btn-dark" : "btn-outline-dark")"
       href="/Invoice/Preview/@ViewBag.InvoiceId?format=clasico">
        Formato clasico
    </a>
    <a class="btn @(format == "fiscal" ? "btn-dark" : "btn-outline-dark")"
       href="/Invoice/Preview/@ViewBag.InvoiceId?format=fiscal">
        Formato fiscal
    </a>
    <a class="btn @(format == "generico" ? "btn-dark" : "btn-outline-dark")"
       href="/Invoice/Preview/@ViewBag.InvoiceId?format=generico">
        Formato generico
    </a>
    <a class="btn @(format == "generico2" ? "btn-dark" : "btn-outline-dark")"
       href="/Invoice/Preview/@ViewBag.InvoiceId?format=generico2">
        Formato generico 2
    </a>
</div>

<iframe id="invoicePreviewFrame"
        src="@printUrl"
        width="100%"
        height="600px"
        style="border:1px solid #ccc;">
</iframe>

<div class="mt-3">
    <button class="btn btn-primary" type="button" id="printInvoiceBtn">
        Imprimir
    </button>

    <a class="btn btn-outline-primary"
       href="@printUrl"
       target="_blank"
       rel="noopener">
        Abrir PDF
    </a>

    <a class="btn btn-secondary"
       href="/Invoice/PrintPos/@ViewBag.InvoiceId"
       target="_blank">
        Ticket POS (texto)
    </a>

    <button class="btn btn-success"
            type="button"
            id="openPrinteraBtn"
            data-pos-url="/Invoice/PrintPos/@ViewBag.InvoiceId">
        Abrir en PrinterA
    </button>

    <a class="btn btn-primary"
       asp-controller="Invoice"
       asp-action="Edit"
       asp-route-id="@ViewBag.InvoiceId">
        Volver
    </a>

    <a class="btn btn-primary"
       asp-controller="Invoice"
       asp-action="Create">
        Crear Factura
    </a>
</div>

<script>
    (function () {
        const printButton = document.getElementById('printInvoiceBtn');
        const previewFrame = document.getElementById('invoicePreviewFrame');
        const button = document.getElementById('openPrinteraBtn');
        const posPath = button?.getAttribute('data-pos-url');
        const posUrl = posPath ? new URL(posPath, window.location.origin).toString() : '';

        if (printButton && previewFrame) {
            printButton.addEventListener('click', function () {
                const frameWindow = previewFrame.contentWindow;
                if (!frameWindow) return;
                frameWindow.focus();
                frameWindow.print();
            });
        }

        if (!button || !posUrl) return;

        async function sharePosTicket() {
            const shareData = {
                title: 'Ticket POS',
                text: 'Abrir ticket en PrinterA',
                url: posUrl
            };

            if (navigator.share) {
                try {
                    await navigator.share(shareData);
                    return true;
                } catch {
                    return false;
                }
            }

            return false;
        }

        async function copyPosUrl() {
            try {
                if (navigator.clipboard?.writeText) {
                    await navigator.clipboard.writeText(posUrl);
                    alert('No se pudo abrir PrinterA automáticamente. URL de ticket copiada.');
                    return;
                }
            } catch {
                // Fallback below
            }

            prompt('Copia esta URL y compártela a PrinterA:', posUrl);
        }

        button.addEventListener('click', async function () {
            // Intento best-effort de deep link hacia PrinterA
            window.location.href = 'printera://';

            // Fallback funcional para iPhone: compartir URL POS
            setTimeout(async function () {
                const shared = await sharePosTicket();
                if (!shared) {
                    await copyPosUrl();
                }
            }, 700);
        });
    })();
</script>
